{# ══════════════════════════════════════════
   NAVBAR — Descovria
   Utilise app.request.attributes pour détecter la page active
   ══════════════════════════════════════════ #}

{% set current_route = app.request.attributes.get('_route') %}

<nav class="navbar navbar-expand-lg navbar-dark ftco_navbar bg-dark ftco-navbar-light" id="ftco-navbar">
    <div class="container">

        {# ── Logo Descovria ── #}
        <a class="navbar-brand" href="{{ path('app_home') }}">
            Descovria<span>Agence de Voyage</span>
        </a>

        {# ── Bouton mobile ── #}
        <button class="navbar-toggler" type="button"
                data-toggle="collapse" data-target="#ftco-nav"
                aria-controls="ftco-nav" aria-expanded="false"
                aria-label="Toggle navigation">
            <span class="oi oi-menu"></span> Menu
        </button>

        {# ── Liens de navigation ── #}
        <div class="collapse navbar-collapse" id="ftco-nav">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item {{ current_route == 'app_home' ? 'active' : '' }}">
                    <a href="{{ path('app_home') }}" class="nav-link">Accueil</a>
                </li>
                <li class="nav-item {{ current_route == 'app_destination' ? 'active' : '' }}">
                    <a href="{{ path('app_destination') }}" class="nav-link">Événements</a>
                </li>
                <li class="nav-item {{ current_route == 'app_hotel' ? 'active' : '' }}">
                    <a href="{{ path('app_hotel') }}" class="nav-link">Produit</a>
                </li>
                <li class="nav-item {{ current_route starts with 'app_covoiturage' ? 'active' : '' }}">
                    <a href="{{ path('app_covoiturage_index') }}" class="nav-link">Covoiturage</a>
                </li>
                <li class="nav-item {{ current_route == 'app_contact' ? 'active' : '' }}">
                    <a href="{{ path('app_contact') }}" class="nav-link">Contacter</a>
                </li>
                <li class="nav-item"><span class="nav-link" style="opacity:0.3">|</span></li>

                {# ── Boutons Auth ── #}
                <li class="nav-item">
                    <a href="{{ path('app_login') }}" class="nav-link">
                        <i class="fa fa-sign-in"></i> Connexion
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_register') }}" class="nav-link btn btn-primary px-3 py-1 ml-2" style="border-radius:20px;">
                        <i class="fa fa-user-plus"></i> S'inscrire
                    </a>
                </li>
            </ul>
        </div>

    </div>
</nav>
{# END nav #}
