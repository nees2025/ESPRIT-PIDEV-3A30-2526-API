{% extends 'layout/base.html.twig' %}
{% block title %}Événements — Descovria{% endblock %}
{% block body %}
    <section class="hero-wrap hero-wrap-2 js-fullheight" style="background-image: url({{ asset('images/bg_1.jpg') }});">
        <div class="overlay"></div>
        <div class="container">
            <div class="row no-gutters slider-text js-fullheight align-items-end justify-content-center">
                <div class="col-md-9 ftco-animate pb-5 text-center">
                    <p class="breadcrumbs">
                        <span class="mr-2"><a href="{{ path('app_home') }}">Accueil <i class="fa fa-chevron-right"></i></a></span>
                        <span>Événements <i class="fa fa-chevron-right"></i></span>
                    </p>
                    <h1 class="mb-0 bread">Nos Événements</h1>
                </div>
            </div>
        </div>
    </section>

    <section class="ftco-section ftco-no-pb">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="search-wrap-1 ftco-animate">
                        <form action="#" class="search-property-1">
                            <div class="row no-gutters">
                                <div class="col-lg d-flex">
                                    <div class="form-group p-4 border-0">
                                        <label>Événement</label>
                                        <div class="form-field">
                                            <div class="icon"><span class="fa fa-search"></span></div>
                                            <input type="text" class="form-control" placeholder="Rechercher un lieu">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg d-flex">
                                    <div class="form-group p-4">
                                        <label>Date d'arrivée</label>
                                        <div class="form-field">
                                            <div class="icon"><span class="fa fa-calendar"></span></div>
                                            <input type="text" class="form-control checkin_date" placeholder="Date d'arrivée">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg d-flex">
                                    <div class="form-group p-4">
                                        <label>Date de départ</label>
                                        <div class="form-field">
                                            <div class="icon"><span class="fa fa-calendar"></span></div>
                                            <input type="text" class="form-control checkout_date" placeholder="Date de départ">
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg d-flex">
                                    <div class="form-group p-4">
                                        <label>Budget</label>
                                        <div class="form-field">
                                            <div class="select-wrap">
                                                <div class="icon"><span class="fa fa-chevron-down"></span></div>
                                                <select class="form-control">
                                                    <option>500 DT</option><option>1 000 DT</option>
                                                    <option>2 000 DT</option><option>5 000 DT</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg d-flex">
                                    <div class="form-group d-flex w-100 border-0">
                                        <div class="form-field w-100 align-items-center d-flex">
                                            <input type="submit" value="Rechercher" class="align-self-stretch form-control btn btn-primary">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="ftco-section">
        <div class="container">
            <div class="row">
                {% set evenements = [
                    {img:'destination-1.jpg',price:'550 DT',days:'8 Jours',name:'Sidi Bou Saïd',loc:'Tunis, Tunisie',type:'mountains'},
                    {img:'destination-2.jpg',price:'650 DT',days:'10 Jours',name:'Djerba Île',loc:'Djerba, Tunisie',type:'beach'},
                    {img:'destination-3.jpg',price:'450 DT',days:'7 Jours',name:'Hammamet',loc:'Hammamet, Tunisie',type:'beach'},
                    {img:'destination-4.jpg',price:'700 DT',days:'8 Jours',name:'Tozeur Désert',loc:'Tozeur, Tunisie',type:'mountains'},
                    {img:'destination-5.jpg',price:'400 DT',days:'5 Jours',name:'Carthage',loc:'Carthage, Tunisie',type:'beach'},
                    {img:'destination-6.jpg',price:'500 DT',days:'6 Jours',name:'Kairouan',loc:'Kairouan, Tunisie',type:'beach'},
                    {img:'destination-7.jpg',price:'480 DT',days:'7 Jours',name:'Tabarka',loc:'Tabarka, Tunisie',type:'beach'},
                    {img:'destination-8.jpg',price:'350 DT',days:'4 Jours',name:'Matmata',loc:'Matmata, Tunisie',type:'mountains'},
                    {img:'destination-9.jpg',price:'550 DT',days:'7 Jours',name:'Nabeul',loc:'Nabeul, Tunisie',type:'beach'},
                ] %}
                {% for e in evenements %}
                <div class="col-md-4 ftco-animate">
                    <div class="project-wrap">
                        <a href="#" class="img" style="background-image: url({{ asset('images/' ~ e.img) }});">
                            <span class="price">{{ e.price }}/pers.</span>
                        </a>
                        <div class="text p-4">
                            <span class="days">{{ e.days }}</span>
                            <h3><a href="#">{{ e.name }}</a></h3>
                            <p class="location"><span class="fa fa-map-marker"></span> {{ e.loc }}</p>
                            <ul>
                                <li><span class="flaticon-shower"></span>2</li>
                                <li><span class="flaticon-king-size"></span>3</li>
                                <li>{% if e.type=='mountains' %}<span class="flaticon-mountains"></span>Montagne{% else %}<span class="flaticon-sun-umbrella"></span>Plage{% endif %}</li>
                            </ul>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
            <div class="row mt-5">
                <div class="col text-center">
                    <div class="block-27">
                        <ul>
                            <li><a href="#">&lt;</a></li>
                            <li class="active"><span>1</span></li>
                            <li><a href="#">2</a></li>
                            <li><a href="#">3</a></li>
                            <li><a href="#">&gt;</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
