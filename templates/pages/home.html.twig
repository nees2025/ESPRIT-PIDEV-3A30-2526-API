{% extends 'layout/base.html.twig' %}

{% block title %}Descovria — Découvrez votre destination de rêve{% endblock %}

{% block body %}

    {# ══ HERO ══ #}
    <div class="hero-wrap js-fullheight" style="background-image: url({{ asset('images/sidibou.jpg') }});">
        <div class="overlay"></div>
        <div class="container">
            <div class="row no-gutters slider-text js-fullheight align-items-center" data-scrollax-parent="true">
                <div class="col-md-7 ftco-animate">
                    <span class="subheading">Bienvenue sur Descovria</span>
                    <h1 class="mb-4">Découvrez notre Tunisie</h1>
                   
                </div>
                <a href="https://vimeo.com/45830194"
                   class="icon-video popup-vimeo d-flex align-items-center justify-content-center mb-4">
                    <span class="fa fa-play"></span>
                </a>
            </div>
        </div>
    </div>

    {# ══ BARRE DE RECHERCHE ══ #}
    <section class="ftco-section ftco-no-pb ftco-no-pt">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="ftco-search d-flex justify-content-center">
                        <div class="row">
                            <div class="col-md-12 nav-link-wrap">
                                <div class="nav nav-pills text-center" id="v-pills-tab" role="tablist">
                                    <a class="nav-link active mr-md-1" id="v-pills-1-tab"
                                       data-toggle="pill" href="#v-pills-1" role="tab">Rechercher un Tour</a>
                                    <a class="nav-link" id="v-pills-2-tab"
                                       data-toggle="pill" href="#v-pills-2" role="tab">Produit</a>
                                </div>
                            </div>
                            <div class="col-md-12 tab-wrap">
                                <div class="tab-content" id="v-pills-tabContent">

                                    {# Tab Tour #}
                                    <div class="tab-pane fade show active" id="v-pills-1" role="tabpanel">
                                        <form action="#" class="search-property-1">
                                            <div class="row no-gutters">
                                                <div class="col-md d-flex">
                                                    <div class="form-group p-4 border-0">
                                                        <label>Événement</label>
                                                        <div class="form-field">
                                                            <div class="icon"><span class="fa fa-search"></span></div>
                                                            <input type="text" class="form-control" placeholder="Rechercher un lieu">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md d-flex">
                                                    <div class="form-group p-4">
                                                        <label>Date d'arrivée</label>
                                                        <div class="form-field">
                                                            <div class="icon"><span class="fa fa-calendar"></span></div>
                                                            <input type="text" class="form-control checkin_date" placeholder="Date d'arrivée">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md d-flex">
                                                    <div class="form-group p-4">
                                                        <label>Date de départ</label>
                                                        <div class="form-field">
                                                            <div class="icon"><span class="fa fa-calendar"></span></div>
                                                            <input type="text" class="form-control checkout_date" placeholder="Date de départ">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md d-flex">
                                                    <div class="form-group p-4">
                                                        <label>Budget maximum</label>
                                                        <div class="form-field">
                                                            <div class="select-wrap">
                                                                <div class="icon"><span class="fa fa-chevron-down"></span></div>
                                                                <select class="form-control">
                                                                    <option value="">500 DT</option>
                                                                    <option value="">1 000 DT</option>
                                                                    <option value="">2 000 DT</option>
                                                                    <option value="">5 000 DT</option>
                                                                    <option value="">10 000 DT</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-md d-flex">
                                                    <div class="form-group d-flex w-100 border-0">
                                                        <div class="form-field w-100 align-items-center d-flex">
                                                            <input type="submit" value="Rechercher"
                                                                   class="align-self-stretch form-control btn btn-primary">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>

                                    {# Tab Produit #}
                                    <div class="tab-pane fade" id="v-pills-2" role="tabpanel">
                                        <form action="#" class="search-property-1">
                                            <div class="row no-gutters">
                                                <div class="col-lg d-flex">
                                                    <div class="form-group p-4 border-0">
                                                        <label>Événement</label>
                                                        <div class="form-field">
                                                            <div class="icon"><span class="fa fa-search"></span></div>
                                                            <input type="text" class="form-control" placeholder="Rechercher un lieu">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-lg d-flex">
                                                    <div class="form-group p-4">
                                                        <label>Date d'arrivée</label>
                                                        <div class="form-field">
                                                            <div class="icon"><span class="fa fa-calendar"></span></div>
                                                            <input type="text" class="form-control checkin_date" placeholder="Date d'arrivée">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-lg d-flex">
                                                    <div class="form-group p-4">
                                                        <label>Date de départ</label>
                                                        <div class="form-field">
                                                            <div class="icon"><span class="fa fa-calendar"></span></div>
                                                            <input type="text" class="form-control checkout_date" placeholder="Date de départ">
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-lg d-flex">
                                                    <div class="form-group p-4">
                                                        <label>Budget maximum</label>
                                                        <div class="form-field">
                                                            <div class="select-wrap">
                                                                <div class="icon"><span class="fa fa-chevron-down"></span></div>
                                                                <select class="form-control">
                                                                    <option value="">500 DT</option>
                                                                    <option value="">1 000 DT</option>
                                                                    <option value="">2 000 DT</option>
                                                                    <option value="">5 000 DT</option>
                                                                </select>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-lg d-flex">
                                                    <div class="form-group d-flex w-100 border-0">
                                                        <div class="form-field w-100 align-items-center d-flex">
                                                            <input type="submit" value="Rechercher"
                                                                   class="align-self-stretch form-control btn btn-primary p-0">
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
    </section>

    {# ══ SERVICES ══ #}
    <section class="ftco-section services-section">
        <div class="container">
            <div class="row d-flex">
                <div class="col-md-6 order-md-last heading-section pl-md-5 ftco-animate d-flex align-items-center">
                    <div class="w-100">
                        <span class="subheading">Bienvenue sur Descovria</span>
                        <h2 class="mb-4">Il est temps de commencer votre aventure</h2>
                        <p>Descovria vous propose les meilleurs événements en Tunisie et dans le monde entier. Nos experts vous accompagnent pour créer des souvenirs inoubliables.</p>
                        <p>Que vous cherchiez une plage paradisiaque, une aventure en montagne ou une immersion culturelle, Descovria a l'offre qu'il vous faut.</p>
                        <p><a href="{{ path('app_destination') }}" class="btn btn-primary py-3 px-4">Explorer les Événements</a></p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="row">
                        <div class="col-md-12 col-lg-6 d-flex align-self-stretch ftco-animate">
                            <div class="services services-1 color-1 d-block img"
                                 style="background-image: url({{ asset('images/services-1.jpg') }});">
                                <div class="icon d-flex align-items-center justify-content-center">
                                    <span class="flaticon-paragliding"></span>
                                </div>
                                <div class="media-body">
                                    <h3 class="heading mb-3">Activités</h3>
                                    <p>Des activités pour tous les goûts — plongée, randonnée, parapente et plus encore.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 col-lg-6 d-flex align-self-stretch ftco-animate">
                            <div class="services services-1 color-2 d-block img"
                                 style="background-image: url({{ asset('images/services-2.jpg') }});">
                                <div class="icon d-flex align-items-center justify-content-center">
                                    <span class="flaticon-route"></span>
                                </div>
                                <div class="media-body">
                                    <h3 class="heading mb-3">Organisation de Voyage</h3>
                                    <p>Nous gérons tout — vols, produits, transferts et excursions.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 col-lg-6 d-flex align-self-stretch ftco-animate">
                            <div class="services services-1 color-3 d-block img"
                                 style="background-image: url({{ asset('images/services-3.jpg') }});">
                                <div class="icon d-flex align-items-center justify-content-center">
                                    <span class="flaticon-tour-guide"></span>
                                </div>
                                <div class="media-body">
                                    <h3 class="heading mb-3">Guide Privé</h3>
                                    <p>Nos guides locaux vous font découvrir les trésors cachés.</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-12 col-lg-6 d-flex align-self-stretch ftco-animate">
                            <div class="services services-1 color-4 d-block img"
                                 style="background-image: url({{ asset('images/services-4.jpg') }});">
                                <div class="icon d-flex align-items-center justify-content-center">
                                    <span class="flaticon-map"></span>
                                </div>
                                <div class="media-body">
                                    <h3 class="heading mb-3">Gestion d'Itinéraire</h3>
                                    <p>Un itinéraire personnalisé adapté à vos envies et votre budget.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ══ CAROUSEL DESTINATIONS ══ #}
    <section class="ftco-section img ftco-select-destination"
             style="background-image: url({{ asset('images/bg_3.jpg') }});">
        <div class="container">
            <div class="row justify-content-center pb-4">
                <div class="col-md-12 heading-section text-center ftco-animate">
                    <span class="subheading">Descovria vous propose</span>
                    <h2 class="mb-4">Choisissez votre Destination</h2>
                </div>
            </div>
        </div>
        <div class="container container-2">
            <div class="row">
                <div class="col-md-12">
                    <div class="carousel-destination owl-carousel ftco-animate">
                        <div class="item">
                            <div class="project-destination">
                                <a href="{{ path('app_destination') }}" class="img"
                                   style="background-image: url({{ asset('images/place-1.jpg') }});">
                                    <div class="text">
                                        <h3>Sidi Bou Saïd</h3>
                                        <span>5 Tours</span>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <div class="item">
                            <div class="project-destination">
                                <a href="{{ path('app_destination') }}" class="img"
                                   style="background-image: url({{ asset('images/place-2.jpg') }});">
                                    <div class="text">
                                        <h3>Djerba</h3>
                                        <span>8 Tours</span>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <div class="item">
                            <div class="project-destination">
                                <a href="{{ path('app_destination') }}" class="img"
                                   style="background-image: url({{ asset('images/place-3.jpg') }});">
                                    <div class="text">
                                        <h3>Hammamet</h3>
                                        <span>6 Tours</span>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <div class="item">
                            <div class="project-destination">
                                <a href="{{ path('app_destination') }}" class="img"
                                   style="background-image: url({{ asset('images/place-4.jpg') }});">
                                    <div class="text">
                                        <h3>Tozeur</h3>
                                        <span>4 Tours</span>
                                    </div>
                                </a>
                            </div>
                        </div>
                        <div class="item">
                            <div class="project-destination">
                                <a href="{{ path('app_destination') }}" class="img"
                                   style="background-image: url({{ asset('images/place-5.jpg') }});">
                                    <div class="text">
                                        <h3>Carthage</h3>
                                        <span>3 Tours</span>
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ══ TOURS EN VEDETTE ══ #}
    <section class="ftco-section">
        <div class="container">
            <div class="row justify-content-center pb-4">
                <div class="col-md-12 heading-section text-center ftco-animate">
                    <span class="subheading">Destinations</span>
                    <h2 class="mb-4">Nos Tours Populaires</h2>
                </div>
            </div>
            <div class="row">
                {% set tours = [
                    {img: 'destination-1.jpg', price: '550 DT', days: '8 Jours', name: 'Sidi Bou Saïd & La Marsa', location: 'Tunis, Tunisie', type: 'mountains'},
                    {img: 'destination-2.jpg', price: '650 DT', days: '10 Jours', name: 'Djerba — Île des Rêves', location: 'Djerba, Tunisie', type: 'beach'},
                    {img: 'destination-3.jpg', price: '450 DT', days: '7 Jours', name: 'Hammamet Plage', location: 'Hammamet, Tunisie', type: 'beach'},
                    {img: 'destination-4.jpg', price: '700 DT', days: '8 Jours', name: 'Tozeur & Désert', location: 'Tozeur, Tunisie', type: 'mountains'},
                    {img: 'destination-5.jpg', price: '400 DT', days: '5 Jours', name: 'Carthage Antique', location: 'Carthage, Tunisie', type: 'beach'},
                    {img: 'destination-6.jpg', price: '500 DT', days: '6 Jours', name: 'Kairouan Sacrée', location: 'Kairouan, Tunisie', type: 'beach'},
                ] %}

                {% for tour in tours %}
                <div class="col-md-4 ftco-animate">
                    <div class="project-wrap">
                        <a href="#" class="img"
                           style="background-image: url({{ asset('images/' ~ tour.img) }});">
                            <span class="price">{{ tour.price }}/pers.</span>
                        </a>
                        <div class="text p-4">
                            <span class="days">{{ tour.days }}</span>
                            <h3><a href="#">{{ tour.name }}</a></h3>
                            <p class="location">
                                <span class="fa fa-map-marker"></span> {{ tour.location }}
                            </p>
                            <ul>
                                <li><span class="flaticon-shower"></span>2</li>
                                <li><span class="flaticon-king-size"></span>3</li>
                                <li>
                                    {% if tour.type == 'mountains' %}
                                        <span class="flaticon-mountains"></span>Montagne
                                    {% else %}
                                        <span class="flaticon-sun-umbrella"></span>Plage
                                    {% endif %}
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

    {# ══ VIDEO SECTION ══ #}
    <section class="ftco-section ftco-about img"
             style="background-image: url({{ asset('images/bg_4.jpg') }});">
        <div class="overlay"></div>
        <div class="container py-md-5">
            <div class="row py-md-5">
                <div class="col-md d-flex align-items-center justify-content-center">
                    <a href="https://vimeo.com/45830194"
                       class="icon-video popup-vimeo d-flex align-items-center justify-content-center mb-4">
                        <span class="fa fa-play"></span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    {# ══ À PROPOS RAPIDE ══ #}
    <section class="ftco-section ftco-about ftco-no-pt img">
        <div class="container">
            <div class="row d-flex">
                <div class="col-md-12 about-intro">
                    <div class="row">
                        <div class="col-md-6 d-flex align-items-stretch">
                            <div class="img d-flex w-100 align-items-center justify-content-center"
                                 style="background-image:url({{ asset('images/about-1.jpg') }});">
                            </div>
                        </div>
                        <div class="col-md-6 pl-md-5 py-5">
                            <div class="row justify-content-start pb-3">
                                <div class="col-md-12 heading-section ftco-animate">
                                    <span class="subheading">À propos de nous</span>
                                    <h2 class="mb-4">Rendez votre voyage mémorable et sûr avec nous</h2>
                                    <p>Descovria est votre partenaire de confiance pour explorer la Tunisie et le monde. Notre équipe passionnée vous prépare des expériences uniques et inoubliables.</p>
                                    <p><a href="{{ path('app_destination') }}" class="btn btn-primary">Réserver votre Destination</a></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ══ TÉMOIGNAGES ══ #}
    <section class="ftco-section testimony-section bg-bottom"
             style="background-image: url({{ asset('images/bg_1.jpg') }});">
        <div class="overlay"></div>
        <div class="container">
            <div class="row justify-content-center pb-4">
                <div class="col-md-7 text-center heading-section heading-section-white ftco-animate">
                    <span class="subheading">Témoignages</span>
                    <h2 class="mb-4">Avis de nos Voyageurs</h2>
                </div>
            </div>
            <div class="row ftco-animate">
                <div class="col-md-12">
                    <div class="carousel-testimony owl-carousel">
                        {% set testimonials = [
                            {name: 'Ahmed Ben Salem', role: 'Chef d\'entreprise', img: 'person_1.jpg', text: 'Descovria a organisé notre voyage de noces parfait à Djerba. Un service exceptionnel du début à la fin !'},
                            {name: 'Fatma Trabelsi', role: 'Enseignante', img: 'person_2.jpg', text: 'Grâce à Descovria, j\'ai découvert des endroits magiques en Tunisie que je ne connaissais pas malgré des années de vie ici.'},
                            {name: 'Mohamed Chabbi', role: 'Ingénieur', img: 'person_3.jpg', text: 'Voyage en famille inoubliable à Tozeur. Les guides étaient passionnants et le service impeccable.'},
                            {name: 'Sonia Mansour', role: 'Médecin', img: 'person_1.jpg', text: 'Je recommande vivement Descovria pour l\'organisation parfaite et les prix très compétitifs.'},
                        ] %}
                        {% for t in testimonials %}
                        <div class="item">
                            <div class="testimony-wrap py-4">
                                <div class="text">
                                    <p class="star">
                                        <span class="fa fa-star"></span><span class="fa fa-star"></span>
                                        <span class="fa fa-star"></span><span class="fa fa-star"></span>
                                        <span class="fa fa-star"></span>
                                    </p>
                                    <p class="mb-4">{{ t.text }}</p>
                                    <div class="d-flex align-items-center">
                                        <div class="user-img"
                                             style="background-image: url({{ asset('images/' ~ t.img) }})"></div>
                                        <div class="pl-3">
                                            <p class="name">{{ t.name }}</p>
                                            <span class="position">{{ t.role }}</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ══ BLOG RÉCENT ══ #}
    <section class="ftco-section">
        <div class="container">
            <div class="row justify-content-center pb-4">
                <div class="col-md-12 heading-section text-center ftco-animate">
                    <span class="subheading">Notre Blog</span>
                    <h2 class="mb-4">Derniers Articles</h2>
                </div>
            </div>
            <div class="row d-flex">
                {% set posts = [
                    {img: 'image_1.jpg', day: '15', month: 'Mars', year: '2026', title: 'Les 10 meilleurs spots de plongée en Tunisie'},
                    {img: 'image_2.jpg', day: '10', month: 'Mars', year: '2026', title: 'Guide complet pour visiter Carthage'},
                    {img: 'image_3.jpg', day: '05', month: 'Mars', year: '2026', title: 'Tozeur : le désert tunisien à couper le souffle'},
                ] %}
                {% for post in posts %}
                <div class="col-md-4 d-flex ftco-animate">
                    <div class="blog-entry justify-content-end">
                        <a href="{{ path('app_blog') }}" class="block-20"
                           style="background-image: url({{ asset('images/' ~ post.img) }});"></a>
                        <div class="text">
                            <div class="d-flex align-items-center mb-4 topp">
                                <div class="one"><span class="day">{{ post.day }}</span></div>
                                <div class="two">
                                    <span class="yr">{{ post.year }}</span>
                                    <span class="mos">{{ post.month }}</span>
                                </div>
                            </div>
                            <h3 class="heading"><a href="#">{{ post.title }}</a></h3>
                            <p><a href="{{ path('app_blog') }}" class="btn btn-primary">Lire la suite</a></p>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </section>

{% endblock %}
